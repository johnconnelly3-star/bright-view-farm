<style type="text/css">
body { font-size: 12px; }
body, #header ul.navigation > li > a { font-family: "Open Sans", serif; }
h1, h2, h3, h4, h5, h6, ul.navigation > li > a { font-family: "Mate SC",serif !important; }
#header.logo-center div.logo {margin-bottom: 13px!important;}
#topbar-wrap { display: none !important; }
#header.logo-center div.logo { padding: 0px 0 0!important; }
#header.logo-center {padding-top: 1px!important;}
#header ul.navigation > li > a {padding: 0 12px 12px;}
#social-icons { position: absolute; }
#social-icons li { height: 20px; overflow: hidden; opacity: 0.4; }
#social-icons li:hover { opacity: 0.8; }
#social-icons li.text { color: #bbb; margin-left: 10px; }
#social-icons li a { margin: 0 4px; }
#social-icons li a img { position: relative; top: -20px; }
.home .slider-default .slider-meta { display: none !important; }
#header ul.navigation > li > a:hover {color: #F7DA08;}
footer[role="contentinfo"] section.copyright {margin-top: -33px;}
.rs-slider .slider-meta { display: none !important; }
</style>

